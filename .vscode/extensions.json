{
  // ============================================
  // VS Code 확장 프로그램 추천 목록 (2025년 최신)
  // ============================================
  // 📝 이 파일은 무엇인가요?
  // 이 프로젝트에서 권장하는 VS Code 확장 프로그램 목록입니다.
  // VS Code로 폴더를 열면 자동으로 설치를 권장합니다.
  //
  // 2025년 최신 React + TypeScript 개발 환경에 최적화되었습니다.

  // ============================================
  // 필수 확장 프로그램 (Must Have)
  // ============================================
  // 프로젝트 작업에 필수적인 확장 프로그램들입니다.

  "recommendations": [
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // 코드 품질 & 포맷팅 (Code Quality & Formatting)
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

    // ESLint
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // 📝 무엇을 하나요?
    // JavaScript/TypeScript 코드 품질 검사 및 자동 수정
    //
    // 2025년 통계: 20M+ 다운로드 (업계 표준)
    //
    // 주요 기능:
    // - 문법 오류 실시간 표시
    // - 코드 스타일 규칙 강제
    // - 저장 시 자동 수정
    // - 잠재적 버그 사전 방지
    //
    // 예시:
    // ❌ const x = 1  // 세미콜론 없음 → 빨간 밑줄
    // ✅ const x = 1; // 저장 시 자동 추가
    "dbaeumer.vscode-eslint",

    // Prettier - Code formatter
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // 📝 무엇을 하나요?
    // 모든 코드를 일관되게 자동 포맷팅
    //
    // 2025년 상태: 가장 인기 있는 코드 포맷터
    //
    // 지원 언어:
    // - JavaScript/TypeScript
    // - React/JSX/TSX
    // - HTML/CSS/SCSS
    // - JSON/YAML/Markdown
    //
    // 주요 기능:
    // - 저장 시 자동 정리
    // - 들여쓰기, 줄바꿈 자동 조정
    // - 팀 전체 일관된 스타일
    //
    // 예시:
    // ❌ const   x={a:1,b:2}
    // ✅ const x = { a: 1, b: 2 };
    "esbenp.prettier-vscode",

    // Stylelint
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // 📝 무엇을 하나요?
    // CSS/SCSS 코드 품질 검사 및 자동 수정
    //
    // 2025년 상태: 공식 확장, 활발히 유지 관리됨
    //
    // 주요 기능:
    // - CSS 문법 오류 실시간 표시
    // - 속성 순서 자동 정렬
    // - 네이밍 규칙 강제
    // - 성능 및 접근성 문제 감지
    //
    // 예시:
    // ❌ .box { color: red; display: flex; }
    // ✅ .box { display: flex; color: red; } // 저장 시 자동 정렬
    "stylelint.vscode-stylelint",

    // Error Lens
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // 📝 무엇을 하나요?
    // 에러 메시지를 코드 옆에 바로 표시
    //
    // 2025년 상태: 필수 확장 프로그램 목록에 지속 등장
    //
    // 주요 기능:
    // - 에러를 코드 라인 끝에 표시
    // - 마우스 올릴 필요 없음
    // - 시각적으로 에러 강조
    // - 디버깅 시간 대폭 단축
    //
    // 예시:
    // const x = 1  ← Missing semicolon (빨간색으로 표시)
    "usernamehw.errorlens",

    // Console Ninja
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // 📝 무엇을 하나요?
    // console.log 출력을 코드 옆에 바로 표시
    //
    // 2025년 상태: 🔥 새로운 필수 디버깅 도구
    //
    // 주요 기능:
    // - console.log 결과를 에디터에 직접 표시
    // - 브라우저 콘솔 열 필요 없음
    // - 실시간 업데이트
    // - 복잡한 객체/배열 탐색 가능
    // - Node.js 및 브라우저 지원
    //
    // 장점:
    // - VS Code와 브라우저 왔다갔다 안 해도 됨
    // - 디버깅 속도 대폭 향상
    // - 제로 설정 (설치만 하면 끝)
    //
    // 예시:
    // console.log(user); // ← 코드 옆에 {name: "John", age: 30} 표시
    "WallabyJs.console-ninja",

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // CSS/SCSS 개발 (Styling)
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

    // SCSS IntelliSense
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // 📝 무엇을 하나요?
    // SCSS 변수, Mixin 자동완성 및 정의 이동
    //
    // 주요 기능:
    // - $변수 자동완성
    // - @mixin 자동완성
    // - @function 자동완성
    // - Ctrl/⌘ + 클릭으로 정의 위치 이동
    // - 사용하지 않는 변수 표시
    //
    // 예시:
    // $primary-color: blue;
    // color: $pr... ← 입력하면 $primary-color 자동완성 제안
    "mrmlnc.vscode-scss",

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // HTML/JSX 편집 도구 (HTML/JSX Tools)
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

    // Auto Rename Tag
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // 📝 무엇을 하나요?
    // HTML/JSX 태그 이름 변경 시 자동으로 쌍 태그도 변경
    //
    // 2025년 통계: 23.5M 설치
    //
    // 주요 기능:
    // - 여는 태그 수정 → 닫는 태그 자동 수정
    // - JSX 컴포넌트 이름 변경 시 유용
    // - React 개발 필수
    //
    // 예시:
    // <div>...</div>
    // <button>... ← div를 button으로 수정하면
    // <button>...</button> ← 자동으로 변경
    "formulahendry.auto-rename-tag",

    // Highlight Matching Tag
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // 📝 무엇을 하나요?
    // 현재 커서의 HTML/JSX 태그 쌍을 강조 표시
    //
    // 2025년 상태: React 개발 추천 목록에 포함
    //
    // 주요 기능:
    // - 커서 위치의 여는/닫는 태그 강조
    // - 상태바에 태그 경로 표시
    // - 복잡한 JSX에서 구조 파악 쉬움
    // - 커스터마이징 가능한 강조 색상
    //
    // 장점:
    // - 중첩된 JSX에서 어느 태그가 쌍인지 즉시 확인
    // - 닫는 태그를 찾느라 스크롤할 필요 없음
    //
    // 예시:
    // <div> ← 여기 클릭하면
    //   <button>
    //     ...
    //   </button>
    // </div> ← 이 태그가 강조됨
    "vincaslt.highlight-matching-tag",

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // 생산성 도구 (Productivity Tools)
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

    // Path Intellisense
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // 📝 무엇을 하나요?
    // 파일 경로 자동완성
    //
    // 주요 기능:
    // - import 경로 자동완성
    // - 상대 경로 자동 제안
    // - @alias 경로 지원 (@components, @utils 등)
    // - 오타 방지
    //
    // 예시:
    // import Button from '@components/... ← 자동완성 제안
    // import './st... ← 파일 목록 표시
    "christian-kohler.path-intellisense",

    // Import Cost
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // 📝 무엇을 하나요?
    // import한 패키지의 크기를 실시간 표시
    //
    // 2025년 통계: 910K+ 다운로드 (2020년 기준)
    //
    // 주요 기능:
    // - 패키지 크기를 코드 옆에 표시
    // - 무거운 라이브러리 식별
    // - 번들 크기 최적화에 유용
    // - Tree shaking 효과 확인
    //
    // 예시:
    // import { Button } from 'antd'; // 200KB (회색으로 표시)
    // import _ from 'lodash'; // 70KB (노란색 경고)
    // import { debounce } from 'lodash'; // 5KB (작은 크기 - 녹색)
    //
    // 팁:
    // - 큰 패키지는 동적 import 고려
    // - 필요한 함수만 import (tree shaking)
    "wix.vscode-import-cost",

    // Todo Tree
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // 📝 무엇을 하나요?
    // TODO, FIXME 주석을 트리 뷰로 정리
    //
    // 2025년 상태: 필수 확장 프로그램 목록에 포함
    //
    // 주요 기능:
    // - 프로젝트 전체 TODO 검색 (ripgrep 사용)
    // - 사이드바에 트리 뷰로 표시
    // - 클릭하면 해당 코드로 이동
    // - 커스텀 태그 지원 (BUG, HACK, NOTE 등)
    // - 색상 및 아이콘 커스터마이징
    //
    // 지원 태그:
    // - TODO: 해야 할 작업
    // - FIXME: 수정 필요
    // - BUG: 버그
    // - HACK: 임시 해결책
    // - NOTE: 메모
    //
    // 예시:
    // // TODO: API 연동 추가
    // // FIXME: 무한 루프 버그 수정
    // // BUG: 로그인 실패 시 에러 처리
    "Gruntfuggly.todo-tree",

    // Better Comments
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // 📝 무엇을 하나요?
    // 주석을 색상별로 강조하여 가독성 향상
    //
    // 2025년 상태: Todo Tree와 함께 사용 권장
    //
    // 주요 기능:
    // - 주석을 종류별로 색상 구분
    // - 중요한 주석을 눈에 띄게 표시
    // - 코드 리뷰 시 유용
    // - 다국어 지원
    //
    // 기본 스타일:
    // - ! 빨간색 (경고)
    // - ? 파란색 (질문)
    // - // 회색 (일반 주석)
    // - TODO 주황색
    // - * 녹색 (중요)
    //
    // 예시:
    // // ! 이 함수는 폐기 예정입니다
    // // ? 이 로직이 맞나요?
    // // TODO: 리팩토링 필요
    // // * 중요: 이 부분은 절대 수정하지 마세요
    "aaron-bond.better-comments",

    // Indent Rainbow
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // 📝 무엇을 하나요?
    // 들여쓰기 단계를 색상으로 시각화
    //
    // 2025년 상태: 가독성 향상 도구로 추천
    //
    // 주요 기능:
    // - 들여쓰기 레벨마다 다른 색상
    // - 중첩 구조 파악 쉬움
    // - JSX 중첩 컴포넌트에 유용
    // - 들여쓰기 오류 즉시 발견
    //
    // 장점:
    // - 복잡한 JSX 구조 이해 쉬움
    // - 들여쓰기 실수 방지
    // - 코드 블록 구분 명확
    //
    // 예시:
    // function Component() {           // 레벨 0
    //   return (                       // 레벨 1 (색상 A)
    //     <div>                        // 레벨 2 (색상 B)
    //       <button>                   // 레벨 3 (색상 C)
    //         Click                    // 레벨 4 (색상 D)
    //       </button>
    //     </div>
    //   );
    // }
    "oderwat.indent-rainbow",

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // Git 도구 (Git Tools)
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

    // GitLens
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // 📝 무엇을 하나요?
    // Git 기능을 VS Code에서 강력하게 사용
    //
    // 2025년 통계: 40M+ 설치 (18M에서 2배 증가!)
    // #1 Git 확장 프로그램
    //
    // 주요 기능:
    // - 각 줄의 마지막 커밋 정보 표시 (Git Blame)
    // - 코드 변경 이력 추적
    // - 파일 히스토리 시각화
    // - 브랜치 비교
    // - 커밋 그래프
    // - 코드 작성자 식별
    //
    // 실용적인 사용 예시:
    // - "이 코드 누가 언제 왜 작성했지?" → 한눈에 확인
    // - "이 버그가 언제 생겼지?" → 커밋 히스토리 추적
    // - "이 함수가 왜 이렇게 작성되었지?" → 커밋 메시지 확인
    //
    // 예시:
    // const x = 1; // John Doe, 2 days ago: Fix login bug (회색으로 표시)
    "eamodio.gitlens"
  ]
}
